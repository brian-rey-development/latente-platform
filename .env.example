# ─── Sanity CMS ──────────────────────────────────────────────────────────────
# Project ID and dataset from sanity.io → project settings
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
# Read token: sanity.io → project → API → Tokens (read-only is sufficient)
SANITY_API_TOKEN=

# ─── ISR Webhook ─────────────────────────────────────────────────────────────
# Shared secret between this app and Sanity webhook config
# Generate: openssl rand -hex 32
REVALIDATE_SECRET=

# ─── PostHog Analytics ───────────────────────────────────────────────────────
# posthog.com → project settings
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ─── Beehiiv Newsletter ──────────────────────────────────────────────────────
# app.beehiiv.com → settings → API
BEEHIIV_API_KEY=
BEEHIIV_PUBLICATION_ID=

# ─── Feature Flags ───────────────────────────────────────────────────────────
# Set to "true" to enable. Gates /tienda, /checkout, and cart in navbar.
NEXT_PUBLIC_FEATURE_STORE_ENABLED=false
# Set to "true" to enable. Gates premium article paywall.
NEXT_PUBLIC_FEATURE_PREMIUM_ENABLED=false
